  setupText: "\uC55E\uC73C\uB85C \uC0AC\uC6A9\uD560 \uBE44\uBC00\uBC88\uD638\uB97C
    \uC785\uB825\uD574\uC8FC\uC138\uC694.\n\uCD5C\uB300 7\uC790\uAE4C\uC9C0 \uC785\uB825
    \uAC00\uB2A5\uD569\uB2C8\uB2E4."
  setupCompleteText: "\uBE44\uBC00\uBC88\uD638 \uC124\uC815 \uC644\uB8CC!"
