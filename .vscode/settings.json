{
    "files.exclude": {
        "**/.DS_Store": true,
        "**/.git": true,
        "**/.vs": true,
        "**/.gitmodules": true,
        "**/.vsconfig": true,
        "**/*.booproj": true,
        "**/*.pidb": true,
        "**/*.suo": true,
        "**/*.user": true,
        "**/*.userprefs": true,
        "**/*.unityproj": true,
        "**/*.dll": true,
        "**/*.exe": true,
        "**/*.pdf": true,
        "**/*.mid": true,
        "**/*.midi": true,
        "**/*.wav": true,
        "**/*.gif": true,
        "**/*.ico": true,
        "**/*.jpg": true,
        "**/*.jpeg": true,
        "**/*.png": true,
        "**/*.psd": true,
        "**/*.tga": true,
        "**/*.tif": true,
        "**/*.tiff": true,
        "**/*.3ds": true,
        "**/*.3DS": true,
        "**/*.fbx": true,
        "**/*.FBX": true,
        "**/*.lxo": true,
        "**/*.LXO": true,
        "**/*.ma": true,
        "**/*.MA": true,
        "**/*.obj": true,
        "**/*.OBJ": true,
        "**/*.asset": true,
        "**/*.cubemap": true,
        "**/*.flare": true,
        "**/*.mat": true,
        "**/*.meta": true,
        "**/*.prefab": true,
        "**/*.unity": true,
        "**/build/": true,
        "**/Build/": true,
        "**/Library/": true,
        "**/library/": true,
        "**/obj/": true,
        "**/Obj/": true,
        "**/Logs/": true,
        "**/logs/": true,
        "**/ProjectSettings/": true,
        "**/UserSettings/": true,
        "**/temp/": true,
        "**/Temp/": true,
        "**/*_BurstDebugInformation_DoNotShip": true
    },
    "files.associations": {
        "*.asset": "yaml",
        "*.meta": "yaml",
        "*.prefab": "yaml",
        "*.unity": "yaml"
    },
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.sln": "*.csproj",
        "*.slnx": "*.csproj"
    },
    "chat.tools.terminal.autoApprove": {
        "/^python -c \"\nimport csv, io\norig = open\\('시나리오 \\(업데이트\\)\\.csv', encoding='utf-8-sig'\\)\\.read\\(\\)\nclean = open\\('시나리오 \\(업데이트\\)_clean\\.csv', encoding='utf-8'\\)\\.read\\(\\)\no_rows = list\\(csv\\.reader\\(io\\.StringIO\\(orig\\)\\)\\)\nc_rows = list\\(csv\\.reader\\(io\\.StringIO\\(clean\\)\\)\\)\n# Value 컬럼\\(idx 3\\) 비교\ndiffs = \\[\\]\nfor i, \\(o, c\\) in enumerate\\(zip\\(o_rows, c_rows\\)\\):\n    ov = o\\[3\\]\\.strip\\(\\) if len\\(o\\) > 3 else ''\n    cv = c\\[3\\]\\.strip\\(\\) if len\\(c\\) > 3 else ''\n    if ov != cv and ov and cv:\n        diffs\\.append\\(\\(i\\+1, ov, cv\\)\\)\nprint\\(f'Value 변경 행 수: \\{len\\(diffs\\)\\}'\\)\nfor ln, ov, cv in diffs\\[:10\\]:\n    print\\(f'  Line \\{ln\\}:'\\)\n    print\\(f'    원본: \\{ov\\}'\\)\n    print\\(f'    정리: \\{cv\\}'\\)\n\"$/": {
            "approve": true,
            "matchCommandLine": true
        }
    },
    "workbench.browser.enableChatTools": true
}